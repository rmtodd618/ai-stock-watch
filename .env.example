# Copy to .env for local use. Do NOT commit real values.
# These map to the *_env_var keys in config.yaml.

# Comma-separated list of recipient email addresses
REPORT_RECIPIENT=you@example.com

# Verified SES sender address (must be verified in SES)
REPORT_SENDER=watchlist@your-verified-domain.com

# Optional: S3 bucket to archive generated reports
REPORT_BUCKET=

# AWS region for SES / S3 / SSM
AWS_REGION=us-east-1

# Anthropic API key — ONLY for local news-sentiment testing. In Lambda the key
# is read from SSM at runtime, not from this var. Leave blank if not testing news.
ANTHROPIC_API_KEY=
